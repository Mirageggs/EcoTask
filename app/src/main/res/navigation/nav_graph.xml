<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- AUTH: Login (start — si ya hay sesión activa, salta directo al Dashboard) -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.trabajofinaldam.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <!-- AUTH: Registro -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.trabajofinaldam.ui.auth.RegisterFragment"
        android:label="Registro"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_registerFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- INICIO -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.trabajofinaldam.ui.dashboard.DashboardFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_dashboard" />

    <!-- NUEVA TAREA -->
    <fragment
        android:id="@+id/newTaskFragment"
        android:name="com.trabajofinaldam.ui.newtask.NewTaskFragment"
        android:label="Nueva"
        tools:layout="@layout/fragment_new_task" />

    <!-- ENFOQUE -->
    <fragment
        android:id="@+id/focusFragment"
        android:name="com.trabajofinaldam.ui.focus.FocusFragment"
        android:label="Enfoque"
        tools:layout="@layout/fragment_focus">
        <argument
            android:name="taskTitle"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="taskId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

</navigation>
