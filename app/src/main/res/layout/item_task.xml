<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/background_task_item"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Barra de prioridad lateral -->
        <View
            android:id="@+id/view_priority_bar"
            android:layout_width="3dp"
            android:layout_height="0dp"
            android:background="@color/eco_green_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Nombre de la tarea -->
        <TextView
            android:id="@+id/tv_task_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Nombre de la tarea"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/view_priority_bar"
            app:layout_constraintEnd_toStartOf="@id/chip_auto"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Hora de la tarea -->
        <TextView
            android:id="@+id/tv_task_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="2dp"
            android:text="00:00 AM"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/view_priority_bar"
            app:layout_constraintEnd_toStartOf="@id/chip_auto"
            app:layout_constraintTop_toBottomOf="@id/tv_task_name" />

        <!-- Badge "Auto-programada" (se oculta si no aplica) -->
        <TextView
            android:id="@+id/chip_auto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto-&#10;programada"
            android:textColor="@color/eco_green_badge_text"
            android:textSize="10sp"
            android:textAlignment="center"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_badge_green"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
