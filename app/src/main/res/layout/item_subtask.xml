<?xml version="1.0" encoding="utf-8"?>
<!--
    item_subtask.xml — Fila de subtarea con checkbox
    Se infla en el RecyclerView de subtareas de activity_focus.xml
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/background_task_item"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- CheckBox de Material Design -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkbox_subtask"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:buttonTint="@color/eco_green_primary" />

        <!-- Nombre de la subtarea -->
        <TextView
            android:id="@+id/tv_subtask_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Nombre de la subtarea"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>