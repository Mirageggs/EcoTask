<?xml version="1.0" encoding="utf-8"?>
<!--
    section_greeting.xml — Encabezado del Dashboard
    Incluye saludo dinámico + chip de Eco-Puntos (ODS 12).
    Se infla mediante <include> en activity_dashboard.xml
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- ============ CHIP DE ECO-PUNTOS (esquina superior) ============ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_eco_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/eco_green_surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/eco_green_badge"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_eco_points_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="🌱 0 Eco-Puntos"
            android:textColor="@color/eco_green_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="🌱 150 Eco-Puntos" />
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ SALUDO ============ -->
    <TextView
        android:id="@+id/tv_greeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Buenas tardes,\nEstudiante!"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.1"
        app:layout_constraintTop_toBottomOf="@id/card_eco_points"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Buenas tardes,\nEstudiante!" />

    <!-- ============ SUBTÍTULO ============ -->
    <TextView
        android:id="@+id/tv_greeting_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Hagamos de hoy un día productivo y sostenible"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_greeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>