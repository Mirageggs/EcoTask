<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_new_task.xml — Pantalla "Nueva Tarea" de EcoTask
    Arquitectura: MVVM  |  Java  |  XML + ConstraintLayout + Material Design
    Replica el diseño Figma: formulario oscuro con descripción, fecha,
    prioridad (toggle), horas y botón "Dividir y Programar con IA".
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_new_task_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- =====================================================
         SCROLL PRINCIPAL (el formulario es largo)
         ===================================================== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_new_task"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- ============ BOTÓN VOLVER ============ -->
            <LinearLayout
                android:id="@+id/layout_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/btn_back_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Volver"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ============ TÍTULO ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nueva Tarea"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp"
                android:text="Ingresa una tarea compleja y deja que la IA la divida en subtareas manejables"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- ============ DESCRIPCIÓN DE LA TAREA ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Descripción de la tarea"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_descripcion"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/background_input"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/eco_green_primary"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_descripcion"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@android:color/transparent"
                    android:gravity="top|start"
                    android:hint="Ej: Completar el proyecto final de investigación sobre computación sostenible..."
                    android:inputType="textMultiLine|textCapSentences"
                    android:padding="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ============ FECHA LÍMITE ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Fecha límite"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_fecha"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/background_input"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/eco_green_primary"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:endIconTint="@color/text_secondary"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_fecha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:hint="dd/mm/aaaa"
                    android:inputType="none"
                    android:padding="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ============ PRIORIDAD (TOGGLE GROUP) ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Prioridad"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_prioridad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <!-- BAJA -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_prioridad_baja"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Baja"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/border_card" />

                <!-- MEDIA (seleccionada por defecto en código) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_prioridad_media"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Media"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/border_card" />

                <!-- ALTA -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_prioridad_alta"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Alta"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/border_card" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- ============ HORAS ESTIMADAS ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Horas estimadas totales (Opcional)"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_horas"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/background_input"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/eco_green_primary"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_horas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Ej: 20"
                    android:inputType="number"
                    android:padding="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ============ BOTÓN "DIVIDIR Y PROGRAMAR CON IA" ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dividir_ia"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="✦  Dividir y Programar con IA"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/background_input"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

            <!-- ============ BANNER "PROGRAMACIÓN INTELIGENTE" ============ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ia_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/eco_green_surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/eco_green_badge"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦"
                        android:textColor="@color/eco_green_primary"
                        android:textSize="18sp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Programación Inteligente con IA"
                            android:textColor="@color/eco_green_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Nuestro algoritmo analizará la complejidad de tu tarea, la dividirá en subtareas óptimas y las programará según tu disponibilidad y patrones de productividad."
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- =====================================================
         BARRA DE NAVEGACIÓN INFERIOR (reutiliza el include)
         ===================================================== -->

</androidx.constraintlayout.widget.ConstraintLayout>