<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_focus.xml — Pantalla "Modo Enfoque" de EcoTask
    Arquitectura: MVVM | Java | XML + ConstraintLayout + Material Design
    Replica el diseño Figma: temporizador Pomodoro, subtareas con checkbox,
    botones de control y contador de Eco-Puntos.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_focus_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_focus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- ============ BOTÓN VOLVER ============ -->
            <LinearLayout
                android:id="@+id/layout_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Volver"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ============ TÍTULO ============ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modo Enfoque"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Nombre de la tarea seleccionada (dinámico) -->
            <TextView
                android:id="@+id/tv_task_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="Completar Proyecto de Investigación"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                tools:text="Completar Proyecto de Investigación" />

            <!-- ============ TARJETA DEL TEMPORIZADOR ============ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TIEMPO DE ENFOQUE"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp"
                        android:letterSpacing="0.15" />

                    <!-- Temporizador: círculo + texto superpuestos -->
                    <FrameLayout
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_focus"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:layout_gravity="center"
                            android:progress="0"
                            android:max="100"
                            app:indicatorColor="@color/eco_green_primary"
                            app:trackColor="@color/progress_background"
                            app:trackThickness="6dp"
                            app:indicatorSize="220dp" />

                        <!-- Texto gigante del temporizador -->
                        <TextView
                            android:id="@+id/tv_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="25:00"
                            android:textColor="@color/eco_green_primary"
                            android:textSize="52sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            tools:text="25:00" />
                    </FrameLayout>

                    <!-- Duración configurable (solo visible antes de iniciar) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_duracion"
                        android:layout_width="180dp"
                        android:layout_height="wrap_content"
                        android:hint="Duración (min)"
                        android:layout_marginBottom="16dp"
                        app:boxBackgroundColor="@color/background_input"
                        app:boxStrokeColor="@color/eco_green_primary"
                        app:hintTextColor="@color/text_secondary"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_duracion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="25"
                            android:gravity="center"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón principal: Iniciar / Pausar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_pause"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="▶  Iniciar Enfoque"
                        android:textColor="@color/background_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/eco_green_primary"
                        app:cornerRadius="28dp"
                        app:elevation="0dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============ ECO-CONSEJO DEL DÍA (dinámico) ============ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/eco_green_surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Cabecera: icono + label -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Eco-Consejo"
                            android:textColor="@color/eco_green_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <!-- Botón: Nuevo consejo -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_nuevo_consejo"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Nuevo"
                            android:textSize="11sp"
                            android:textColor="@color/eco_green_primary"
                            android:textAllCaps="false"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            app:strokeColor="@color/eco_green_badge"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <!-- Texto del consejo (dinámico) -->
                    <TextView
                        android:id="@+id/tv_eco_consejo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Inicia tu sesión para recibir un Eco-Consejo 🌿"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============ SUBTAREAS ============ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtareas pendientes"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_subtask_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 / 5 completadas"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            tools:text="2 / 5 completadas" />
                    </LinearLayout>

                    <!-- RecyclerView de subtareas (con checkbox en item) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_subtasks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============ ECO-PUNTOS DE LA SESIÓN ============ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/eco_green_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏅"
                        android:textSize="28sp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eco-Puntos ganados"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="En esta sesión de enfoque"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Contador de Eco-Puntos de la sesión (dinámico) -->
                    <TextView
                        android:id="@+id/tv_eco_points"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0"
                        android:textColor="@color/eco_green_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="+0" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============ BOTÓN FINALIZAR ============ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_finish"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Finalizar y Sumar Eco-Puntos"
                android:textColor="@color/eco_green_primary"
                android:textSize="15sp"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                app:strokeColor="@color/eco_green_badge" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Barra de navegación inferior (reutiliza el include) -->

</androidx.constraintlayout.widget.ConstraintLayout>